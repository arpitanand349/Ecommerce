{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ecommerce-backend-g1wv.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://ecommerce-backend-g1wv.onrender.com/uploads/:path*"
    },
    {
      "source": "/(css|js)/(.*)",
      "destination": "/frontend/$1/$2"
    },
    {
      "source": "/(.*\\.html)",
      "destination": "/frontend/$1"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    }
  ]
}